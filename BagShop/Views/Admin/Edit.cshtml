@model Bag
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>تعديل بيانات الشنطة ✏️</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light" style="direction: rtl; text-align: right;">

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow border-0 p-4">
                    <h3 class="text-center mb-4 fw-bold text-primary">تعديل بيانات الحقيبة ✏️</h3>

                    <form action="/Admin/Edit" method="post">
                        <input type="hidden" name="BagId" value="@Model.BagId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">اسم الشنطة</label>
                            <input type="text" name="BagName" value="@Model.BagName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">الماركة</label>
                            <input type="text" name="Brand" value="@Model.Brand" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">اللون</label>
                            <input type="text" name="Color" value="@Model.Color" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">السعر ($)</label>
                            <input type="number" step="0.01" name="Price" value="@Model.Price" class="form-control" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">حفظ التعديلات الجديدة 💾</button>
                        <a href="/Admin/Index" class="btn btn-outline-secondary w-100 type="button" class="btn btn-success w-100 py-2 my-2 fw-bold">تسجيل الحساب ✨</button>
                        </form>

                        <div class="text-center mt-3">
                            <p class="text-muted">لديك حساب بالفعل؟ <a href="/Home/Login" class="text-decoration-none fw-bold">تسجيل الدخول</a></p>
                            <a href="/Home/Index" class="text-decoration-none text-secondary small">← العودة للرئيسية</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </body>
</html>