@model List<Bag>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>متجر الحقائب 👜 - الرئيسية</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light" style="direction: rtl; text-align: right;">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">متجر الشنط الفاخرة 👜</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/Home/Index">الرئيسية</a>
                <a class="nav-link btn btn-primary text-white px-3 mx-2" href="/Home/Login">تسجيل الدخول 🔐</a>
                <a class="nav-link btn btn-success text-white px-3" href="/Home/SignUp">إنشاء حساب ✨</a>
            </div>
        </div>
    </nav>

    <div class="container my-5 text-center py-5 bg-white rounded shadow-sm">
        <h1 class="display-4 fw-bold text-primary mb-3">مرحباً بك في متجرنا 🛍️</h1>
        <p class="lead text-muted">تصفح تشكيلتنا الفاخرة وسجل دخولك لإتمام عملية الشراء!</p>
    </div>

    <div class="container mb-5">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var bag in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3">
                            <div class="card-body text-center p-4">

                                <div class="mb-3" style="height: 200px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                    @if (bag.BagId == 1 || bag.BagId == 2 || bag.BagId == 3)
                                    {
                                        <img src="~/images/@(bag.BagId).png"
                                             class="img-fluid rounded-3"
                                             alt="@bag.BagName"
                                             style="max-height: 100%; max-width: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <img src="~/images/default.png"
                                             class="img-fluid rounded-3"
                                             alt="صورة احتياطية"
                                             style="max-height: 100%; max-width: 100%; object-fit: cover;" />
                                    }
                                </div>

                                <h4 class="card-title fw-bold">@bag.BagName</h4>
                                <h6 class="card-subtitle mb-3 text-muted">الماركة: @bag.Brand</h6>
                                <p class="card-text"><span class="badge bg-secondary p-2">اللون: @(bag.Color ?? "عام")</span></p>

                                <h3 class="text-success fw-bold my-3">$ @bag.Price</h3>

                                <div class="mt-3">
                                    @if (bag.UserId != null)
                                    {
                                        <button class="btn btn-sm btn-secondary w-100 fw-bold" disabled>مباع 🎉</button>
                                    }
                                    else
                                    {
                                        <a href="/User/Buy/@bag.BagId" class="btn btn-sm btn-success w-100 fw-bold">شراء الآن 🛒</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted lead">لا توجد حقائب معروضة في المتجر حالياً.</p>
                </div>
            }
        </div>
    </div>
</body>
</html>